<Window
    x:Class="Dlt645Master.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="DL/T645 电能表主站"
    Width="1360"
    Height="820"
    MinWidth="1280"
    MinHeight="768"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{StaticResource WindowBackgroundBrush}"
    Foreground="{StaticResource TextPrimaryBrush}"
    mc:Ignorable="d">
    <!--
        slice-05 正式深色 HMI 界面：标题栏 + 左侧控制面板 + 中间卡片墙/三相电压趋势图 + 右侧报文抽屉 + 底部状态栏。
        颜色一律引用 DarkTheme.xaml 令牌，布局中不散写色值；数值与报文用等宽字体（MonoFont）。
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ============ 标题栏：应用名 + 连接状态徽标 + 报文抽屉开关 ============  -->
        <Border
            Grid.Row="0"
            Padding="14,8"
            Background="{StaticResource PrimaryBrush}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="DL/T645 电能表主站" />
                    <Border
                        Margin="12,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Background="{StaticResource WindowBackgroundBrush}"
                        CornerRadius="9">
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="DL/T645-2007 · RS485" />
                    </Border>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <!--  连接状态徽标：圆点 + 文本，随 IsConnected 变色  -->
                    <Border
                        Padding="10,3"
                        VerticalAlignment="Center"
                        Background="{StaticResource WindowBackgroundBrush}"
                        CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                x:Name="ConnectionDot"
                                Width="9"
                                Height="9"
                                VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource OfflineBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="未连接" />
                                        <Setter Property="Foreground" Value="{StaticResource OfflineBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text" Value="已连接" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ToggleButton
                        x:Name="FrameDrawerToggle"
                        Margin="10,0,0,0"
                        Content="报文监视"
                        IsChecked="True"
                        Style="{StaticResource DrawerToggleStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  ============ 主区：左侧控制面板 | 中间卡片墙 + 趋势图 | 右侧报文抽屉 ============  -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  左侧控制面板  -->
            <Border
                Grid.Column="0"
                Padding="12"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  串口配置：slice-05 仅做禁用占位，真实串口运行时切换留给后续切片  -->
                        <TextBlock
                            Margin="0,0,0,4"
                            Style="{StaticResource SectionHeaderTextStyle}"
                            Text="串口配置" />
                        <Border
                            Padding="6,3"
                            HorizontalAlignment="Left"
                            Background="{StaticResource WindowBackgroundBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="9">
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource AccentHoverBrush}"
                                Text="仿真模式 · 内存回环" />
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="端口" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                IsEnabled="False"
                                Text="COM3（占位）" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="参数" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                IsEnabled="False"
                                Text="2400 bps · 8E1" />
                        </Grid>

                        <!--  电表地址  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="电表地址（12 位 hex，显示序）" />
                        <TextBox FontFamily="{StaticResource MonoFont}" Text="{Binding MeterAddressText, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  数据项勾选  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="数据项" />
                        <ItemsControl ItemsSource="{Binding DataItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        Margin="0,3"
                                        Content="{Binding Name}"
                                        IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  命令按钮：可用态跟随 CanExecute 自动变灰  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="操作" />
                        <UniformGrid Columns="2">
                            <Button
                                Margin="0,0,4,0"
                                Command="{Binding ConnectCommand}"
                                Content="连接"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                Margin="4,0,0,0"
                                Command="{Binding DisconnectCommand}"
                                Content="断开" />
                        </UniformGrid>
                        <UniformGrid Margin="0,8,0,0" Columns="2">
                            <Button
                                Margin="0,0,4,0"
                                Command="{Binding StartPollingCommand}"
                                Content="启动轮询"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                Margin="4,0,0,0"
                                Command="{Binding StopPollingCommand}"
                                Content="停止轮询" />
                        </UniformGrid>
                        <Button
                            Margin="0,8,0,0"
                            Command="{Binding ReadOnceCommand}"
                            Content="单次读取" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  中间区：上卡片墙 / 下趋势图  -->
            <Grid Grid.Column="1" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.15*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <!--  实时电参数卡片墙  -->
                <Border
                    Grid.Row="0"
                    Padding="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Readings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="220" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!--  电参数卡片：项名 + 大号等宽数值 + 单位 + 更新时间；失败整卡转红  -->
                                    <Border Margin="5" Padding="12,9">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="CornerRadius" Value="6" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding ItemName}" />
                                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="26" FontWeight="Bold" Text="{Binding Value, TargetNullValue=--}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="6,0,0,4"
                                                    VerticalAlignment="Bottom"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Unit}" />
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontFamily="{StaticResource MonoFont}"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding UpdateTime, StringFormat='更新 {0:HH:mm:ss}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!--  三相电压趋势图 + 250V 警戒线  -->
                <Border
                    Grid.Row="2"
                    Padding="12,8"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="三相电压趋势（最近 120 次采样）" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="11"
                                Foreground="{StaticResource DangerBrush}"
                                Text="— — 250V 上限警戒线" />
                        </DockPanel>
                        <lvc:CartesianChart
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            AnimationsSpeed="0:0:0"
                            LegendPosition="Top"
                            Sections="{Binding VoltageSections}"
                            Series="{Binding VoltageSeries}"
                            XAxes="{Binding VoltageXAxes}"
                            YAxes="{Binding VoltageYAxes}" />
                        <!--  空态提示：三相电压一项都未勾选时覆盖图表，不报错  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            Visibility="{Binding IsVoltageChartUnsubscribed, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="未订阅三相电压——请在左侧勾选 A/B/C 相电压数据项" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!--  右侧报文监视抽屉（ToggleButton 开合）  -->
            <Border
                Grid.Column="2"
                Width="340"
                Padding="10"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="6"
                Visibility="{Binding IsChecked, ElementName=FrameDrawerToggle, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="2,0,2,6">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="报文监视" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource WarningBrush}"
                                Text="■ 发送" />
                            <TextBlock
                                Margin="8,0,0,0"
                                FontSize="11"
                                Foreground="{StaticResource SuccessBrush}"
                                Text="■ 接收" />
                        </StackPanel>
                    </DockPanel>
                    <!--  上限 500 条，必须开启 UI 虚拟化；新条目由代码隐藏自动滚到底  -->
                    <ListBox
                        x:Name="FrameLogList"
                        Grid.Row="1"
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="11"
                        ItemsSource="{Binding FrameLog}"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.ScrollUnit="Item"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--  Tx/Rx 按方向着色（方向标签 + hex 继承前景色，时间戳保持次要色）  -->
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="TextElement.Foreground" Value="{StaticResource SuccessBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Direction}" Value="Tx">
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock
                                        Width="86"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" />
                                    <TextBlock Width="34" Text="{Binding DirectionText}" />
                                    <TextBlock Text="{Binding HexText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!--  ============ 状态栏：StatusMessage + 收发统计 ============  -->
        <Border
            Grid.Row="2"
            Padding="14,6"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource ControlBorderBrush}"
            BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    TextElement.FontFamily="{StaticResource MonoFont}">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Tx " />
                    <TextBlock Text="{Binding TxCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Rx " />
                    <TextBlock Text="{Binding RxCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource WarningBrush}"
                        Text="超时 " />
                    <TextBlock Text="{Binding TimeoutCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource DangerBrush}"
                        Text="错误 " />
                    <TextBlock Text="{Binding ErrorCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="RTT " />
                    <TextBlock Text="{Binding LastRoundTripMs, StringFormat='{}{0:F1} ms'}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
