<Window
    x:Class="Dlt645Master.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Dlt645Master.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    Title="DL/T645 电能表主站"
    Width="1360"
    Height="820"
    MinWidth="1280"
    MinHeight="768"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{StaticResource WindowBackgroundBrush}"
    Foreground="{StaticResource TextPrimaryBrush}"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    <!--
        slice-06：WindowChrome 自定义标题栏（并入顶栏）。CaptionHeight 与顶栏 44 高度对齐，
        保证空白处拖拽、双击最大化、分屏吸附等系统行为；窗控按钮须 IsHitTestVisibleInChrome 才点得到。
        WindowStyle=None 下最大化盖任务栏的问题由代码隐藏的 WM_GETMINMAXINFO 钩子处理（限制在工作区内）。
    -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="44"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:VoltageToRatioConverter x:Key="VoltageToRatio" />
        <conv:VoltageLevelConverter x:Key="VoltageLevel" />

        <!--
            卡片墙分组视图：按 GroupName 分四组（电能/电压/电流/功率与频率），
            组序与组内顺序用 GroupOrder/SortOrder 锁定，不依赖读数到达顺序
        -->
        <CollectionViewSource x:Key="GroupedReadings" Source="{Binding Readings}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="GroupOrder" />
                <scm:SortDescription PropertyName="SortOrder" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ============ 标题栏（即 WindowChrome 标题区）：应用名 + 连接徽标 + 报文开关 + 窗控按钮 ============  -->
        <Border
            Grid.Row="0"
            Height="44"
            Background="{StaticResource PrimaryBrush}">
            <DockPanel>
                <!--  窗控按钮贴右缘（系统惯例），Stretch 吃满标题栏高度  -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button
                        x:Name="MinimizeButton"
                        Click="OnMinimizeClick"
                        Content="&#xE921;"
                        Style="{StaticResource WindowControlButtonStyle}"
                        ToolTip="最小化"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button
                        x:Name="MaximizeRestoreButton"
                        Click="OnMaximizeRestoreClick"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style BasedOn="{StaticResource WindowControlButtonStyle}" TargetType="Button">
                                <Setter Property="Content" Value="&#xE922;" />
                                <Setter Property="ToolTip" Value="最大化" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                        <Setter Property="Content" Value="&#xE923;" />
                                        <Setter Property="ToolTip" Value="向下还原" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button
                        x:Name="CloseButton"
                        Click="OnCloseClick"
                        Content="&#xE8BB;"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        ToolTip="关闭"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>

                <!--  连接状态徽标 + 报文抽屉开关  -->
                <StackPanel
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Border
                        Padding="10,3"
                        VerticalAlignment="Center"
                        Background="{StaticResource WindowBackgroundBrush}"
                        CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                x:Name="ConnectionDot"
                                Width="9"
                                Height="9"
                                VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource OfflineBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="未连接" />
                                        <Setter Property="Foreground" Value="{StaticResource OfflineBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text" Value="已连接" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ToggleButton
                        x:Name="FrameDrawerToggle"
                        Margin="10,0,0,0"
                        Content="报文监视"
                        IsChecked="True"
                        Style="{StaticResource DrawerToggleStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>

                <!--  应用名与协议徽标  -->
                <StackPanel
                    Margin="14,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="DL/T645 电能表主站" />
                    <Border
                        Margin="12,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Background="{StaticResource WindowBackgroundBrush}"
                        CornerRadius="9">
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="DL/T645-2007 · RS485" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  ============ 主区：左侧控制面板 | 中间卡片墙 + 趋势图 | 右侧报文抽屉 ============  -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  左侧控制面板  -->
            <Border
                Grid.Column="0"
                Padding="12"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  串口配置：禁用占位，真实串口运行时切换留给后续切片  -->
                        <TextBlock
                            Margin="0,0,0,4"
                            Style="{StaticResource SectionHeaderTextStyle}"
                            Text="串口配置" />
                        <Border
                            Padding="6,3"
                            HorizontalAlignment="Left"
                            Background="{StaticResource WindowBackgroundBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="9">
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource AccentHoverBrush}"
                                Text="仿真模式 · 内存回环" />
                        </Border>
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="端口" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                IsEnabled="False"
                                Text="COM3（占位）" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="参数" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                IsEnabled="False"
                                Text="2400 bps · 8E1" />
                        </Grid>

                        <!--  电表地址  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="电表地址（12 位 hex，显示序）" />
                        <TextBox FontFamily="{StaticResource MonoFont}" Text="{Binding MeterAddressText, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  数据项勾选  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="数据项" />
                        <ItemsControl ItemsSource="{Binding DataItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        Margin="0,3"
                                        Content="{Binding Name}"
                                        IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  命令按钮：可用态跟随 CanExecute 自动变灰  -->
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="操作" />
                        <UniformGrid Columns="2">
                            <Button
                                Margin="0,0,4,0"
                                Command="{Binding ConnectCommand}"
                                Content="连接"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                Margin="4,0,0,0"
                                Command="{Binding DisconnectCommand}"
                                Content="断开" />
                        </UniformGrid>
                        <UniformGrid Margin="0,8,0,0" Columns="2">
                            <Button
                                Margin="0,0,4,0"
                                Command="{Binding StartPollingCommand}"
                                Content="启动轮询"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                Margin="4,0,0,0"
                                Command="{Binding StopPollingCommand}"
                                Content="停止轮询" />
                        </UniformGrid>
                        <Button
                            Margin="0,8,0,0"
                            Command="{Binding ReadOnceCommand}"
                            Content="单次读取" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  中间区：上卡片墙 / 下趋势图  -->
            <Grid Grid.Column="1" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.15*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <!--
                    实时电参数卡片墙：四组横排成等宽列、组内卡片纵向等分吃满高度——任意窗口尺寸下一屏尽览，
                    刻意不套 ScrollViewer（MinWidth/MinHeight 已保证最小可用空间）；断开连接整墙转离线灰（保留末次数值）
                -->
                <Border
                    Grid.Row="0"
                    Padding="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="6">
                    <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedReadings}}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <!--
                                    自定义 GroupItem 模板：DockPanel 让组标题置顶、ItemsPresenter 吃满剩余高度
                                    （默认模板是 StackPanel，组内条目不会纵向拉伸）
                                -->
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="GroupItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GroupItem">
                                                    <DockPanel>
                                                        <TextBlock
                                                            DockPanel.Dock="Top"
                                                            Style="{StaticResource GroupHeaderTextStyle}"
                                                            Text="{Binding Name}" />
                                                        <ItemsPresenter />
                                                    </DockPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <!--  组面板：单行 UniformGrid 把各组横排成等宽列（GroupStyle.Panel 承载的是「组」本身）  -->
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!--  组内叶子卡片：单列 UniformGrid 纵向等分组列高度（分组时 ItemsPanel 承载的是组内条目）  -->
                                <UniformGrid Columns="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--
                                    电参数卡片：左分类色带 + 项名 + 大号数值/单位/涨跌箭头 +（电压卡）250V 进度条 + 更新时间。
                                    失败整卡转红；IsConnected=False 时整卡去饱和转离线灰（触发器写在各元素样式最后，压过失败红）
                                -->
                                <Border Margin="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="6" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                    <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  分类色带：电压三卡用相色（与趋势图图例一致），其余用组色  -->
                                        <Border
                                            Grid.Column="0"
                                            Width="4"
                                            CornerRadius="6,0,0,6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource OfflineBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="PhaseA">
                                                            <Setter Property="Background" Value="{StaticResource PhaseABrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="PhaseB">
                                                            <Setter Property="Background" Value="{StaticResource PhaseBBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="PhaseC">
                                                            <Setter Property="Background" Value="{StaticResource PhaseCBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="Energy">
                                                            <Setter Property="Background" Value="{StaticResource CategoryEnergyBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="Current">
                                                            <Setter Property="Background" Value="{StaticResource CategoryCurrentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccentToken}" Value="Power">
                                                            <Setter Property="Background" Value="{StaticResource CategoryPowerBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource OfflineBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!--  内容垂直居中：组内卡片纵向等分后高度可能大于内容，居中比顶对齐更匀称  -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="12,7"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding ItemName}" />
                                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    FontFamily="{StaticResource MonoFont}"
                                                    FontSize="24"
                                                    FontWeight="Bold"
                                                    Text="{Binding Value, TargetNullValue=--}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource OfflineBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="6,0,0,4"
                                                    VerticalAlignment="Bottom"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Unit}" />
                                                <!--  涨跌箭头：升绿降黄（红在本界面语义是错误/超限，刻意不用）；电能类恒 Flat 不显示  -->
                                                <TextBlock
                                                    Margin="8,0,0,5"
                                                    VerticalAlignment="Bottom"
                                                    FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Trend}" Value="Up">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Text" Value="▲" />
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Trend}" Value="Down">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Text" Value="▼" />
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource OfflineBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!--  电压卡底部进度条：当前值对 250V 上限占比，接近上限转黄、越限转红（转换器 + 令牌，纯绑定）  -->
                                            <Border
                                                Height="4"
                                                Margin="0,6,0,0"
                                                Background="{StaticResource WindowBackgroundBrush}"
                                                CornerRadius="2"
                                                Visibility="{Binding IsVoltage, Converter={StaticResource BoolToVisibility}}">
                                                <Rectangle
                                                    HorizontalAlignment="Stretch"
                                                    RadiusX="2"
                                                    RadiusY="2"
                                                    RenderTransformOrigin="0,0.5">
                                                    <Rectangle.RenderTransform>
                                                        <ScaleTransform ScaleX="{Binding Value, Converter={StaticResource VoltageToRatio}}" />
                                                    </Rectangle.RenderTransform>
                                                    <Rectangle.Style>
                                                        <Style TargetType="Rectangle">
                                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Value, Converter={StaticResource VoltageLevel}}" Value="High">
                                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Value, Converter={StaticResource VoltageLevel}}" Value="Over">
                                                                    <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Fill" Value="{StaticResource OfflineBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Rectangle.Style>
                                                </Rectangle>
                                            </Border>

                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontFamily="{StaticResource MonoFont}"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding UpdateTime, StringFormat='更新 {0:HH:mm:ss}'}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!--  三相电压趋势图 + 250V 警戒线  -->
                <Border
                    Grid.Row="2"
                    Padding="12,8"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="三相电压趋势（最近 120 次采样）" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="11"
                                Foreground="{StaticResource DangerBrush}"
                                Text="— — 250V 上限警戒线" />
                        </DockPanel>
                        <lvc:CartesianChart
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            AnimationsSpeed="0:0:0"
                            LegendPosition="Top"
                            Sections="{Binding VoltageSections}"
                            Series="{Binding VoltageSeries}"
                            XAxes="{Binding VoltageXAxes}"
                            YAxes="{Binding VoltageYAxes}" />
                        <!--  空态提示：三相电压一项都未勾选时覆盖图表，不报错  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            Visibility="{Binding IsVoltageChartUnsubscribed, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="未订阅三相电压——请在左侧勾选 A/B/C 相电压数据项" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!--  右侧报文监视抽屉（ToggleButton 开合）  -->
            <Border
                Grid.Column="2"
                Width="360"
                Padding="10"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="6"
                Visibility="{Binding IsChecked, ElementName=FrameDrawerToggle, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="2,0,2,6">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="报文监视" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource WarningBrush}"
                                Text="■ 发送" />
                            <TextBlock
                                Margin="8,0,0,0"
                                FontSize="11"
                                Foreground="{StaticResource SuccessBrush}"
                                Text="■ 接收" />
                        </StackPanel>
                    </DockPanel>
                    <!--
                        上限 500 条，必须开启 UI 虚拟化；新条目由代码隐藏自动滚到底。
                        两行结构：第一行时间戳 + 方向徽标，第二行报文本体自动换行——任何宽度下不出横向滚动条
                    -->
                    <ListBox
                        x:Name="FrameLogList"
                        Grid.Row="1"
                        ItemsSource="{Binding FrameLog}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.ScrollUnit="Item"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--  相邻条目以细分隔线区隔，两行结构下不做区隔会糊成一片  -->
                                <Border
                                    Padding="0,3,0,4"
                                    BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource MonoFont}"
                                                FontSize="10"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="5,0,5,1"
                                                VerticalAlignment="Center"
                                                CornerRadius="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="Tx">
                                                                <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="{StaticResource WindowBackgroundBrush}"
                                                    Text="{Binding DirectionText}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="10"
                                            LineHeight="14"
                                            LineStackingStrategy="BlockLineHeight"
                                            Text="{Binding HexText}"
                                            TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Tx">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!--  ============ 状态栏：StatusMessage + 收发统计 ============  -->
        <Border
            Grid.Row="2"
            Padding="14,6"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource ControlBorderBrush}"
            BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    TextElement.FontFamily="{StaticResource MonoFont}">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Tx " />
                    <TextBlock Text="{Binding TxCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Rx " />
                    <TextBlock Text="{Binding RxCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource WarningBrush}"
                        Text="超时 " />
                    <TextBlock Text="{Binding TimeoutCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource DangerBrush}"
                        Text="错误 " />
                    <TextBlock Text="{Binding ErrorCount}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="RTT " />
                    <TextBlock Text="{Binding LastRoundTripMs, StringFormat='{}{0:F1} ms'}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
